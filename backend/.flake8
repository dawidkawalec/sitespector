[flake8]
max-line-length = 100
exclude = 
    __pycache__,
    .git,
    .venv,
    venv,
    ENV,
    alembic,
    build,
    dist
ignore = 
    E203,  # whitespace before ':'
    E501,  # line too long (handled by black)
    W503,  # line break before binary operator
per-file-ignores =
    __init__.py:F401

