# Database Configuration
DATABASE_URL=postgresql+asyncpg://sitespector_user:CHANGE_PASSWORD_HERE@postgres:5432/sitespector_db

# Authentication
JWT_SECRET=GENERATE_RANDOM_64_CHARACTER_SECRET_HERE

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Screaming Frog License (Optional - free version works with limitations)
SCREAMING_FROG_USER=your_sf_username
SCREAMING_FROG_KEY=your_sf_license_key
SCREAMING_FROG_EMAIL=your_email@example.com

# Application Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
